{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "boundaries": {
    "zones": [
      { "name": "app", "patterns": ["src/routes/**"] },
      { "name": "features/process", "patterns": ["src/features/process/**"] },
      {
        "name": "shared",
        "patterns": [
          "src/components/**",
          "src/hooks/**",
          "src/lib/**",
          "src/providers/**",
          "src/stores/**"
        ]
      }
    ],
    "rules": [
      { "from": "app", "allow": ["features/process", "shared"] },
      { "from": "features/process", "allow": ["shared"] },
      { "from": "shared", "allow": [] }
    ]
  },
  "duplicates": {
    "skipLocal": true
  },
  "ignorePatterns": ["src/components/ui/**", "convex/**", "generateKeys.mjs"],
  "ignoreDependencies": [
    "@ai-hero/sandcastle",
    "@components/ui",
    "@convex/_generated",
    "class-variance-authority",
    "jose",
    "netlify-cli",
    "next-themes",
    "radix-ui",
    "react-doctor",
    "react-scan",
    "shadcn",
    "sharp",
    "vaul",
    "zod"
  ]
}
