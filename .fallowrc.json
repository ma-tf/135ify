{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "boundaries": {
    "zones": [
      { "name": "app", "patterns": ["src/routes/**"] },
      { "name": "features/process", "patterns": ["src/features/process/**"] },
      {
        "name": "shared",
        "patterns": [
          "src/components/**",
          "src/hooks/**",
          "src/lib/**",
          "src/providers/**",
          "src/stores/**"
        ]
      }
    ],
    "rules": [
      { "from": "app", "allow": ["features/process", "shared"] },
      { "from": "features/process", "allow": ["shared"] },
      { "from": "shared", "allow": [] }
    ]
  },
  "duplicates": {
    "skipLocal": true
  },
  "ignorePatterns": ["src/components/ui/**", "convex/**"],
  "ignoreDependencies": [
    "@components/ui",
    "shadcn",
    "class-variance-authority",
    "radix-ui",
    "vaul",
    "@ai-hero/sandcastle",
    "zod",
    "@convex/_generated"
  ]
}
